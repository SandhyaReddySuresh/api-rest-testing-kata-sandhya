{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Room",
  "type": "object",
  "required": ["roomid", "roomName", "type", "accessible", "image", "description", "features", "roomPrice"],
  "properties": {
    "roomid": {
      "type": "integer",
      "minimum": 1
    },
    "roomName": {
      "type": "string",
      "minLength": 1
    },
    "type": {
      "type": "string",
      "enum": ["Single", "Double", "Suite", "Deluxe"]
    },
    "accessible": {
      "type": "boolean"
    },
    "image": {
      "type": "string",
      "format": "uri",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "features": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 0
    },
    "roomPrice": {
      "type": "number",
      "minimum": 0
    }
  },
  "additionalProperties": false
}