{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "type": "object",
  "required": ["rooms"],
  "properties": {
    "rooms": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "required": [
          "roomid",
          "roomName",
          "type",
          "accessible",
          "image",
          "description",
          "features",
          "roomPrice"
        ],
        "properties": {
          "roomid": {
            "type": "number"
          },
          "roomName": {
            "type": "string",
            "minLength": 1
          },
          "type": {
            "type": "string",
            "minLength": 1
          },
          "accessible": {
            "type": "boolean"
          },
          "image": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "features": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "roomPrice": {
            "type": "number"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}